{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfjulyten"
		},
		"LS_ADLS_BLOB_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_ADLS_BLOB'"
		},
		"LS_ADLS_TO_BLOB_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_TO_BLOB'"
		},
		"LS_CSV_DATA_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_CSV_DATA'"
		},
		"LS_SQL_MIGRATION_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQL_MIGRATION'"
		},
		"SqlServer1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SqlServer1'"
		},
		"LS_ADLS_TO_BLOB_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsgen2julydemo.dfs.core.windows.net/"
		},
		"LS_CSV_DATA_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsgen2julydemo.dfs.core.windows.net/"
		},
		"LS_SQL_MIGRATION_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost\\SQLEXPRESS"
		},
		"LS_SQL_MIGRATION_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "Visionboardmigration"
		},
		"LS_SQL_MIGRATION_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "vasanthi"
		},
		"SqlServer1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost\\SQLEXPRESS"
		},
		"SqlServer1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "Visionboardmigration"
		},
		"SqlServer1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "vasanthi"
		},
		"EVENT_TRIGGER_BLOB_ADLS_CSV_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/7a4801aa-2a10-4e2e-a581-95eb6abf0633/resourceGroups/vasuup/providers/Microsoft.Storage/storageAccounts/blobjulydemo"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfjulyten_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_BLOB_connectionString": {
						"value": "[parameters('LS_ADLS_BLOB_connectionString')]"
					},
					"LS_ADLS_TO_BLOB_accountKey": {
						"value": "[parameters('LS_ADLS_TO_BLOB_accountKey')]"
					},
					"LS_CSV_DATA_accountKey": {
						"value": "[parameters('LS_CSV_DATA_accountKey')]"
					},
					"LS_SQL_MIGRATION_password": {
						"value": "[parameters('LS_SQL_MIGRATION_password')]"
					},
					"SqlServer1_password": {
						"value": "[parameters('SqlServer1_password')]"
					},
					"LS_ADLS_TO_BLOB_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_TO_BLOB_properties_typeProperties_url')]"
					},
					"LS_CSV_DATA_properties_typeProperties_url": {
						"value": "[parameters('LS_CSV_DATA_properties_typeProperties_url')]"
					},
					"LS_SQL_MIGRATION_properties_typeProperties_server": {
						"value": "[parameters('LS_SQL_MIGRATION_properties_typeProperties_server')]"
					},
					"LS_SQL_MIGRATION_properties_typeProperties_database": {
						"value": "[parameters('LS_SQL_MIGRATION_properties_typeProperties_database')]"
					},
					"LS_SQL_MIGRATION_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQL_MIGRATION_properties_typeProperties_userName')]"
					},
					"SqlServer1_properties_typeProperties_server": {
						"value": "[parameters('SqlServer1_properties_typeProperties_server')]"
					},
					"SqlServer1_properties_typeProperties_database": {
						"value": "[parameters('SqlServer1_properties_typeProperties_database')]"
					},
					"SqlServer1_properties_typeProperties_userName": {
						"value": "[parameters('SqlServer1_properties_typeProperties_userName')]"
					},
					"EVENT_TRIGGER_BLOB_ADLS_CSV_properties_typeProperties_scope": {
						"value": "[parameters('EVENT_TRIGGER_BLOB_ADLS_CSV_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}